" ============================================
" МИНИМАЛЬНЫЙ КОНФИГ Vim
" ============================================

" ----- ВНЕШНИЙ ВИД -----
syntax on               " Включить подсветку синтаксиса
set number              " Показывать номера строк

" ----- ТАБУЛЯЦИЯ И ОТСТУПЫ -----
set tabstop=4           " Ширина табуляции = 4 пробела
set shiftwidth=4        " Ширина отступа = 4 пробела
set expandtab           " Превращать Tab в пробелы
set autoindent          " Автоматический отступ

" ----- ПОВЕДЕНИЕ -----
set hidden              " Позволять переключать файлы без сохранения
set undofile            " Сохранять историю отмен между сессиями
set undodir=~/.vim/undo " Папка для истории отмен
set backupdir=~/.vim/backup " Папка для резервных копий
set directory=~/.vim/swap   " Папка для временных файлов

" ----- КОДИРОВКИ -----
set encoding=utf-8      " Внутренняя кодировка Vim
set fileencoding=utf-8  " Кодировка новых файлов

" ----- ИНТЕРФЕЙС -----
set ruler               " Показывать позицию курсора внизу
set mouse=a             " Включить поддержку мыши

" ============================================
" КОНЕЦ КОНФИГА
" ============================================
